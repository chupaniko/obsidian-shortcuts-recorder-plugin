{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": "./src",
    "strict": true,
    "types": [
      "node",
      "obsidian"
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
